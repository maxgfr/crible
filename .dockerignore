.github
.claude
data
site-data
*.duckdb
*.duckdb.wal
.venv
__pycache__
*.py[cod]
.pytest_cache
.ruff_cache
.hypothesis
ui/node_modules
ui/dist
ui/tsconfig.tsbuildinfo
tests
docs
.env
Dockerfile
docker-compose.yml
